{
  "name": "philippine-skyland-platform",
  "version": "1.0.0",
  "description": "Philippine Skyland MGT and DEVT OPC (PPSMDO) - Licensed Real Estate Broker and Appraiser Platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed-production.js && node prisma/seed-test-accounts.js",
    "deploy:local": "npm run build && npm run start"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^0.5.0",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.67.0",
    "@vercel/analytics": "^2.0.1",
    "autoprefixer": "^10.4.19",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "gray-matter": "^4.0.3",
    "next": "^16.2.11",
    "next-auth": "^4.24.15",
    "next-intl": "^4.13.3",
    "nodemailer": "^9.0.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.11",
    "prettier": "^3.2.0",
    "prisma": "^5.14.0",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "postcss": "^8.5.22",
    "sharp": "^0.35.3",
    "nodemailer": "^9.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "prisma@5.22.0": true,
    "unrs-resolver@1.12.2": true
  }
}
